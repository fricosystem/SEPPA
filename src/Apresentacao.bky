<xml xmlns="https://developers.google.com/blockly/xml"><block type="when_button_clicked" x="100" y="100"><title name="BUTTON">BotaoEntrar</title><statement name="DO"><block type="if" x="100" y="150"><title name="CONDITION">TinyDB.GetValue("usuario_logado") == "true"</title><statement name="THEN"><block type="open_screen" x="100" y="200"><title name="SCREEN">TelaPrincipal</title></block><block type="show_notification" x="100" y="250"><title name="TITLE">Bem-vindo!</title><title name="MESSAGE">Você está logado!</title></block></statement><statement name="ELSE"><block type="show_message" x="100" y="300"><title name="MESSAGE">Você precisa fazer login primeiro!</title></block><block type="ask_for_login" x="100" y="350"><title name="TITLE">Login</title></block><block type="if" x="100" y="400"><title name="CONDITION">login_bem_sucedido</title><statement name="THEN"><block type="open_screen" x="100" y="450"><title name="SCREEN">TelaPrincipal</title></block><block type="show_notification" x="100" y="500"><title name="TITLE">Login bem-sucedido!</title><title name="MESSAGE">Você está logado!</title></block></statement><statement name="ELSE"><block type="show_notification" x="100" y="550"><title name="TITLE">Erro no login</title><title name="MESSAGE">Tente novamente!</title></block></statement></block></statement></block></statement></block></xml>