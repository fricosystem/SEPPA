<xml xmlns="https://developers.google.com/blockly/xml"><block type="when_button_clicked" x="100" y="100"><title name="BUTTON">BotaoEntrar</title><statement name="DO"><block type="if" x="100" y="150"><title name="CONDITION">TinyDB.GetValue("usuario_logado") == "true"</title><statement name="THEN"><block type="open_screen" x="100" y="200"><title name="SCREEN">TelaPrincipal</title></block></statement><statement name="ELSE"><block type="show_message" x="100" y="250"><title name="MESSAGE">Vocę precisa fazer login primeiro!</title></block></statement></block></statement></block></xml>